  "keyFeatures": [
    "SPARQL 1.1 query and update support for deterministic reasoning over knowledge graphs",
    "Hybrid semantic search combining vector similarity, keyword precision, and graph-based filters",
    "AI SDK integration with first-class LLM tool-calling support via @wazoo/worlds-ai-sdk",
    "TypeScript SDK (@wazoo/worlds-sdk) and CLI (@wazoo/worlds-cli) for programmatic and terminal access",
    "Edge-first architecture powered by Deno and Turso (libSQL) for low-latency operations",
    "RDF import/export supporting Turtle, N-Quads, N-Triples, and N3 formats",
    "Provider-agnostic: works with any LLM (OpenAI, Anthropic, Gemini, etc.)",
    "Worlds Console web interface for visual graph management and query testing"
  ],
  "publicApiSurface": [
    "WorldsSdk — main SDK entry point with worlds client",
    "Worlds.list(options?) — paginate all worlds",
    "Worlds.get(id) — retrieve a world by ID",
    "Worlds.create(data) — create a new world",
    "Worlds.update(id, data) — update a world",
    "Worlds.delete(id) — soft-delete a world",
    "Worlds.sparql(id, query, options?) — execute SPARQL query or update",
    "Worlds.search(id, query, options?) — hybrid semantic/graph search",
    "Worlds.import(id, data, options?) — import RDF data",
    "Worlds.export(id, options?) — export world as RDF",
    "Worlds.listLogs(id, options?) — retrieve world operation logs",
    "createTools(options) — AI SDK tool set for LLM tool-calling (worlds-ai-sdk)",
    "GET /worlds — list worlds",
    "POST /worlds — create world",
    "GET /worlds/:world — get world",
    "PUT /worlds/:world — update world",
    "DELETE /worlds/:world — delete world",
    "POST /worlds/:world/sparql — execute SPARQL",
    "GET /worlds/:world/search — semantic/graph search",
    "POST /worlds/:world/import — import RDF data",
    "GET /worlds/:world/export — export RDF data",
    "GET /worlds/:world/logs — retrieve logs"
  ]
}
